<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Panel principal -->

    <Style x:Key="MainContentGridStyle"
           TargetType="Grid">

        <Setter Property="Margin"
                Value="25"/>

    </Style>

    <!-- Separador -->

    <Style x:Key="SectionSeparatorStyle"
           TargetType="Separator">

        <Setter Property="Margin"
                Value="0,15"/>

    </Style>

</ResourceDictionary>