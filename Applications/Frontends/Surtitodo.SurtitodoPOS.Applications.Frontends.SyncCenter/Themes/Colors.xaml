<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- === MARCA SURTITODO === -->
    <Color x:Key="PrimaryColor">#E31E24</Color>
    <Color x:Key="PrimaryDarkColor">#B01419</Color>
    <Color x:Key="PrimaryHoverColor">#FF3A40</Color>

    <!-- === FONDOS === -->
    <Color x:Key="WindowBackgroundColor">#181820</Color>
    <Color x:Key="SidebarBackgroundColor">#1E1E26</Color>
    <Color x:Key="CardBackgroundColor">#22222A</Color>
    <Color x:Key="CardBackgroundHoverColor">#2A2A34</Color>
    <Color x:Key="ConsoleBgColor">#16161C</Color>

    <!-- === BORDES === -->
    <Color x:Key="BorderColor">#32323C</Color>
    <Color x:Key="BorderAccentColor">#42424E</Color>

    <!-- === TEXTO === -->
    <Color x:Key="TextColor">#F2F2F5</Color>
    <Color x:Key="TextSecondaryColor">#8A8A9A</Color>
    <Color x:Key="TextMutedColor">#55556A</Color>

    <!-- === ESTADOS === -->
    <Color x:Key="SuccessColor">#22C55E</Color>
    <Color x:Key="WarningColor">#F59E0B</Color>
    <Color x:Key="ErrorColor">#EF4444</Color>
    <Color x:Key="StoppedColor">#52526A</Color>
    <Color x:Key="InfoColor">#60A5FA</Color>

    <!-- === BOTONES === -->
    <Color x:Key="ButtonGhostBgColor">#24242E</Color>
    <Color x:Key="ButtonGhostHoverColor">#2E2E3A</Color>
    <Color x:Key="ButtonDangerBgColor">#2D1414</Color>

</ResourceDictionary>
