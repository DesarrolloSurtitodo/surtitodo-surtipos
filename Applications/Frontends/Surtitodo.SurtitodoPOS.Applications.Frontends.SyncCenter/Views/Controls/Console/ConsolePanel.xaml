<UserControl x:Class="Surtitodo.SurtitodoPOS.Applications.Frontends.SyncCenter.Views.Controls.Console.ConsolePanel"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        ConsolePanel rediseñada:
        - Fondo casi negro (#0D0D0F)
        - Header con label de sección
        - ScrollViewer con ItemsControl para líneas individuales con badge + mensaje
        - El code-behind rellena el ItemsSource externamente
          (o bien se puede seguir usando la propiedad Text para compatibilidad)
    -->
    <Border Background="{DynamicResource ConsoleBgBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="10">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header consola -->
            <Border Grid.Row="0"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="16,10">
                <TextBlock Text="{Binding Title, ElementName=Root}"
                           FontSize="10"
                           FontWeight="Bold"

                           Foreground="{DynamicResource TextSecondaryBrush}"/>
            </Border>

            <!-- Contenido: ItemsControl (líneas con badge) -->
            <ScrollViewer Grid.Row="1"
                          x:Name="Scroller"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="0,4,0,4">
                <ItemsControl x:Name="LogItems">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="108"/>
                                    <ColumnDefinition Width="44"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Timestamp -->
                                <TextBlock Grid.Column="0"
                                           Padding="14,3,6,3"
                                           FontFamily="Cascadia Code, Consolas, monospace"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           VerticalAlignment="Center"
                                           Text="{Binding TimeDisplay}"/>

                                <!-- Badge tipo -->
                                <Border Grid.Column="1"
                                        Margin="0,2,4,2"
                                        CornerRadius="4"
                                        Padding="5,2"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        Background="{Binding BadgeBackground}">
                                    <TextBlock FontFamily="Cascadia Code, Consolas, monospace"
                                               FontSize="10"
                                               FontWeight="Bold"
                                               Foreground="{Binding BadgeForeground}"
                                               Text="{Binding TypeLabel}"
                                               HorizontalAlignment="Center"/>
                                </Border>

                                <!-- Mensaje -->
                                <TextBlock Grid.Column="2"
                                           Padding="6,3,14,3"
                                           FontFamily="Cascadia Code, Consolas, monospace"
                                           FontSize="12"
                                           Foreground="{Binding MessageForeground}"
                                           Text="{Binding Message}"
                                           TextTrimming="None"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

        </Grid>
    </Border>
</UserControl>
