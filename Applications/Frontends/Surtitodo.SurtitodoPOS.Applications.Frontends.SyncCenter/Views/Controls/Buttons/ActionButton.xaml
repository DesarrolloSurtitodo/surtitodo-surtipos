<UserControl x:Class="Surtitodo.SurtitodoPOS.Applications.Frontends.SyncCenter.Views.Controls.Buttons.ActionButton"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Button
        Command="{Binding Command, ElementName=Root}"
        IsEnabled="{Binding IsEnabled, ElementName=Root}"
        Padding="16,10"
        Margin="4"
        MinWidth="130"
        Cursor="Hand">

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center">

            <TextBlock
                Margin="0,0,8,0"
                FontSize="16"
                VerticalAlignment="Center"
                Text="{Binding Icon, ElementName=Root}" />

            <TextBlock
                FontWeight="SemiBold"
                VerticalAlignment="Center"
                Text="{Binding Text, ElementName=Root}" />

        </StackPanel>

    </Button>

</UserControl>