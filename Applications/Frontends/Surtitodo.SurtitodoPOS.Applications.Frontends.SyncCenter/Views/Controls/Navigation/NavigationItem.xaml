<UserControl x:Class="Surtitodo.SurtitodoPOS.Applications.Frontends.SyncCenter.Views.Controls.Navigation.NavigationItem"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             d:DesignHeight="58" d:DesignWidth="220"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">

    <Border x:Name="Container"
            Margin="0,3"
            Padding="10,10"
            Background="Transparent"
            CornerRadius="8"
            Cursor="Hand">

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Indicador de estado -->
            <Ellipse x:Name="StatusEllipse"
                     Grid.Column="0"
                     Width="8" Height="8"
                     VerticalAlignment="Center"/>

            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                <TextBlock x:Name="TitleText"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextBrush}"
                           Text="{Binding Title, ElementName=Root}"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock x:Name="SubtitleText"
                           Margin="0,3,0,0"
                           FontSize="11"
                           Foreground="{DynamicResource TextMutedBrush}"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
