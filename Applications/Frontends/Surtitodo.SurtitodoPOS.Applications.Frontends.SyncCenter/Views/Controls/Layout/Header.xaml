<UserControl x:Class="Surtitodo.SurtitodoPOS.Applications.Frontends.SyncCenter.Views.Controls.Layout.Header"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:badges="clr-namespace:Surtitodo.SurtitodoPOS.Applications.Frontends.SyncCenter.Views.Controls.Badges">

    <Border Padding="0,0,0,18"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,0,0,1"
            Margin="0,0,0,20">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Título + subtítulo -->
            <StackPanel Grid.Column="0">
                <TextBlock FontFamily="Segoe UI Variable Display, Segoe UI"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextBrush}"
                           Text="{Binding Title, ElementName=Root}"/>
                <TextBlock Margin="0,5,0,0"
                           FontSize="13"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Text="{Binding Subtitle, ElementName=Root}"/>
            </StackPanel>

            <!-- Derecha: status pill + última actualización -->
            <StackPanel Grid.Column="1"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">

                <!-- Status badge compacto -->
                <badges:StatusBadge x:Name="HeaderStatusBadge"
                                    VerticalAlignment="Center"
                                    Margin="0,0,20,0"/>

                <!-- Última actualización -->
                <StackPanel VerticalAlignment="Center">
                    <TextBlock FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}"
                               HorizontalAlignment="Right"
                               Text="Última actualización"/>
                    <TextBlock x:Name="LastUpdateText"
                               Margin="0,3,0,0"
                               FontFamily="Cascadia Code, Consolas"
                               FontSize="13"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Right"
                               Foreground="{DynamicResource TextBrush}"
                               Text="{Binding LastUpdate, ElementName=Root}"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
