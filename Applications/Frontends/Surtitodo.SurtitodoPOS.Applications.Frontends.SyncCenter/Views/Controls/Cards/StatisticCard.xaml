<UserControl x:Class="Surtitodo.SurtitodoPOS.Applications.Frontends.SyncCenter.Views.Controls.Cards.StatisticCard"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        La card tiene:
        - Fondo oscuro elevado
        - Borde izquierdo grueso con el color de acento (AccentBrush)
        - Label en MAYÚSCULAS pequeño arriba
        - Número grande en el acento
        - Subtítulo muted abajo
    -->
    <Border Background="{DynamicResource CardBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Margin="0,0,10,0">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Borde izquierdo de acento -->
            <Rectangle Grid.Column="0"
                       Fill="{Binding AccentBrush, ElementName=Root}"
                       RadiusX="10" RadiusY="2"/>

            <StackPanel Grid.Column="1" Margin="18,16,18,16">

                <!-- Label -->
                <TextBlock FontSize="10"
                           FontWeight="Bold"

                           Foreground="{DynamicResource TextMutedBrush}"
                           Text="{Binding Title, ElementName=Root}"/>

                <!-- Valor -->
                <TextBlock FontFamily="Segoe UI Variable Display, Segoe UI"
                           FontSize="36"
                           FontWeight="Bold"
                           Margin="0,6,0,4"
                           Foreground="{Binding AccentBrush, ElementName=Root}"
                           Text="{Binding Value, ElementName=Root}"/>

                <!-- Subtítulo -->
                <TextBlock FontSize="11"
                           Foreground="{DynamicResource TextMutedBrush}"
                           Text="{Binding Subtitle, ElementName=Root}"/>

            </StackPanel>
        </Grid>
    </Border>
</UserControl>
